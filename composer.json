{
  "name": "aliqasemzadeh/jetadmin",
  "description": "Laravel Bootstrap Admin Panel with all basic features by using livewire.",
  "keywords": ["admin", "bootstrap", "admin-panel", "laravel", "dashboard", "ticketing", "bootstrap", "tabler", "admin-ui"],
  "license": "MIT",
  "authors": [
    {
      "name": "Ali Qasemzadeh",
      "email": "AliQasemzadeh7@gmail.com",
      "role": "Developer"
    }
  ],
  "minimum-stability": "dev",
  "require": {
    "php": "~8.0.0 || ~8.1.0 || ~8.2.0",
    "aliqasemzadeh/livewire-bootstrap-modal": "*",
    "arcanedev/log-viewer": "*",
    "creativeorange/gravatar": "*",
    "cybercog/laravel-ban": "*",
    "guzzlehttp/guzzle": "*",
    "jantinnerezo/livewire-alert": "*",
    "laravel/framework": "*",
    "laravel/jetstream": "*",
    "laravel/sanctum": "*",
    "laravel/tinker": "*",
    "league/commonmark": "*",
    "livewire/livewire": "*",
    "maatwebsite/excel": "*",
    "mcamara/laravel-localization": "*",
    "morilog/jalali": "*",
    "nesbot/carbon": "*",
    "questocat/laravel-referral": "*",
    "spatie/laravel-activitylog": "*",
    "spatie/laravel-medialibrary": "*",
    "spatie/laravel-permission": "*",
    "spatie/laravel-tags": "*",
    "tucker-eric/eloquentfilter": "*",
    "yadahan/laravel-authentication-log": "*"
  },
  "require-dev": {
    "spatie/laravel-ignition": "*",
    "fakerphp/faker": "*",
    "laravel/sail": "*",
    "mockery/mockery": "*",
    "nunomaduro/collision": "*",
    "phpunit/phpunit": "*"
  },
  "autoload": {
    "psr-4": {
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/",
      "AliQasemzadeh\\JetAdmin\\": "src"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "AliQasemzadeh\\JetAdmin\\Providers\\JetAdminServiceProvider"
      ]
    }
  }
}
